# ═══════════════════════════════════════════════════════════════════════════════
# ProofBook — every environment variable, and which SERVICE it belongs to.
#
# Three services, three environments. The split is the security model:
#   KEEPER  holds the signing key that creates and settles markets
#   API     holds only a faucet key that can move a valueless devnet token
#   WEB     holds NO secrets at all
#
# Anything prefixed NEXT_PUBLIC_ is compiled INTO THE BROWSER BUNDLE and is world
# readable. Never put a key, a secret, or an RPC URL with an API key behind one.
# ═══════════════════════════════════════════════════════════════════════════════


# ─────────────────────────────────────────────────────────────────────────────
# SHARED — database
# ─────────────────────────────────────────────────────────────────────────────
# Postgres. The keeper WRITES it; the API only READS it. Managed Postgres
# (Neon/Railway/Supabase) is fine. Include ?sslmode=require for a hosted DB.
DATABASE_URL=postgresql://user:pass@host:5432/proofbook?schema=public


# ═════════════════════════════════════════════════════════════════════════════
# KEEPER  (the long-running worker — must be alive to settle the semis + Final)
# ═════════════════════════════════════════════════════════════════════════════

# SECRET. The market authority AND the escrow mint authority. This key settles
# markets. It must exist ONLY here — never in the API, never in the web app.
# A JSON byte array (solana-keygen output) or a path to that file.
ANCHOR_WALLET=/absolute/path/to/id.json

# Solana RPC. A dedicated endpoint (Helius/Triton/QuickNode) — the public devnet
# RPC rate-limits hard once you touch 100+ markets.
RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# The generation of markets the seeder WROTE to.
MARKET_TYPE=3
# The generations the reader SURFACES. Devnet keeps every market ever created and
# they cannot be deleted, so generations accumulate; a fixture is deduped to one
# market and a settled market always wins.
MARKET_TYPES=3,4

# Identifies this keeper in keeper_runs (the status page shows it). Railway/Fly
# set their own replica id; otherwise hostname-pid is used.
# KEEPER_INSTANCE=keeper-prod-1

# TxLINE (the oracle's data API).
TXLINE_API=https://txline-dev.txodds.com
COMPETITION_ID=72

# Optional: pins the escrow mint instead of auto-creating one.
# USDC_MINT=3Srypwg8r4L4PbCcBeSgjveeixyH6sKAytJK11xVTMns

# Set by the platform; shown on the status page so you know what is deployed.
# GIT_SHA=


# ═════════════════════════════════════════════════════════════════════════════
# API  (stateless read layer + faucet — safe to scale horizontally)
# ═════════════════════════════════════════════════════════════════════════════

PORT=8787
HOST=0.0.0.0
LOG_LEVEL=info

# Comma-separated allowed origins. Set this to the real web URL in production —
# leaving it as * lets any site call the faucet.
CORS_ORIGINS=https://your-web-url.vercel.app

RATE_LIMIT_MAX=300

# Solana RPC. The API needs it ONLY to broadcast faucet transactions.
RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# SECRET — but a LOW-PRIVILEGE one. This wallet can only transfer a valueless
# devnet token and a little SOL. It is NOT the keeper's key and cannot settle
# anything. Produced by `npm run faucet:setup`.
FAUCET_SECRET_KEY=[1,2,3,...]
# The demo token the markets escrow. Public information.
USDC_MINT=3Srypwg8r4L4PbCcBeSgjveeixyH6sKAytJK11xVTMns

# Faucet policy.
FAUCET_USDC=10000          # handed out per grant
FAUCET_SOL=0.02            # enough to pay rent for a Position account
FAUCET_USDC_CEILING=5000   # don't top up a wallet that already has this much
FAUCET_MAX_GRANTS=5        # per wallet, ever
FAUCET_COOLDOWN_SEC=30
FAUCET_RATE_MAX=10         # requests per IP per minute


# ═════════════════════════════════════════════════════════════════════════════
# WEB  (Next.js — NO SECRETS)
# ═════════════════════════════════════════════════════════════════════════════

# Public API base URL. Not a secret; anyone can curl it.
NEXT_PUBLIC_API_URL=https://your-api-url.up.railway.app
# Used only to build an absolute RPC-proxy URL during SSR.
NEXT_PUBLIC_SITE_URL=https://your-web-url.vercel.app

# SECRET, and SERVER-SIDE ONLY (note: no NEXT_PUBLIC_ prefix).
# The browser never sees this. It calls /api/rpc on our own origin, and that
# route — running on the server — forwards to this URL. Putting the key in a
# NEXT_PUBLIC_ var would publish it to anyone who opens devtools.
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
RPC_PROXY_RATE_MAX=240
