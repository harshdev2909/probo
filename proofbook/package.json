{
  "name": "proofbook",
  "version": "0.1.0",
  "license": "ISC",
  "private": true,
  "workspaces": [
    "keeper"
  ],
  "scripts": {
    "test": "NODE_OPTIONS='--no-experimental-strip-types' ts-mocha -p ./tsconfig.json -t 1000000 tests/*.ts",
    "keeper:live": "NODE_OPTIONS='--no-experimental-strip-types' ts-node -P keeper/tsconfig.json keeper/src/index.ts live",
    "keeper:replay": "NODE_OPTIONS='--no-experimental-strip-types' ts-node -P keeper/tsconfig.json keeper/src/index.ts replay",
    "keeper:capture": "NODE_OPTIONS='--no-experimental-strip-types' ts-node -P keeper/tsconfig.json keeper/src/index.ts capture",
    "keeper:e2e": "./keeper/scripts/e2e.sh",
    "lint:fix": "prettier \"tests/**/*.ts\" \"keeper/src/**/*.ts\" -w",
    "lint": "prettier \"tests/**/*.ts\" \"keeper/src/**/*.ts\" --check",
    "demo:seed": "./keeper/scripts/demo-seed.sh",
    "coverage": "NODE_OPTIONS='--no-experimental-strip-types' ts-node -P keeper/tsconfig.json keeper/scripts/coverage.ts",
    "seed:markets": "NODE_OPTIONS='--no-experimental-strip-types' ts-node -P keeper/tsconfig.json keeper/scripts/seed-tournament.ts",
    "seed:liquidity": "NODE_OPTIONS='--no-experimental-strip-types' ts-node -P keeper/tsconfig.json keeper/scripts/seed-liquidity.ts",
    "backfill": "NODE_OPTIONS='--no-experimental-strip-types' ts-node -P keeper/tsconfig.json keeper/scripts/backfill-settle.ts",
    "demo:tournament": "./scripts/tournament.sh",
    "db:migrate": "prisma migrate dev --schema db/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema db/prisma/schema.prisma",
    "db:generate": "prisma generate --schema db/prisma/schema.prisma",
    "db:import": "NODE_OPTIONS='--no-experimental-strip-types' ts-node -P keeper/tsconfig.json db/src/import.ts",
    "db:studio": "prisma studio --schema db/prisma/schema.prisma",
    "api": "NODE_OPTIONS='--no-experimental-strip-types' ts-node -P keeper/tsconfig.json api/src/index.ts",
    "faucet:setup": "NODE_OPTIONS='--no-experimental-strip-types' ts-node -P keeper/tsconfig.json keeper/scripts/setup-faucet.ts",
    "smoke": "NODE_OPTIONS='--no-experimental-strip-types' ts-mocha -p ./tsconfig.json -t 180000 tests/e2e/smoke-judge-path.ts",
    "test:api": "NODE_OPTIONS='--no-experimental-strip-types' ts-mocha -p ./tsconfig.json -t 60000 tests/e2e/api.test.ts",
    "db:backup": "./scripts/backup-db.sh",
    "test:e2e": "npm run test:api && npm run smoke",
    "idl:sync": "cp target/idl/proofbook.json idl/proofbook.json && cp target/idl/mock_oracle.json idl/mock_oracle.json && cp target/idl/proofbook.json web/lib/idl/proofbook.json && echo \"IDL synced to idl/ and web/lib/idl/\"",
    "postinstall": "prisma generate --schema db/prisma/schema.prisma",
    "start:api": "NODE_OPTIONS='--no-experimental-strip-types' ts-node --transpile-only -P keeper/tsconfig.json api/src/index.ts",
    "start:keeper": "NODE_OPTIONS='--no-experimental-strip-types' ts-node --transpile-only -P keeper/tsconfig.json keeper/src/index.ts live"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@fastify/compress": "^9.0.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/etag": "^6.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@prisma/client": "^6.19.3",
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "axios": "1.7.9",
    "eventsource": "^4.1.0",
    "fastify": "^5.10.0",
    "js-sha3": "0.9.3",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.3",
    "ts-node": "10.9.2",
    "tweetnacl": "1.0.3",
    "typescript": "5.7.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bn.js": "5.2.0",
    "@types/chai": "4.3.20",
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.0",
    "chai": "4.5.0",
    "mocha": "10.8.2",
    "prettier": "2.8.8",
    "ts-mocha": "11.1.0"
  },
  "engines": {
    "node": "22.x"
  }
}
