.anchor
.DS_Store
target
**/*.rs.bk
node_modules
test-ledger
.yarn
.surfpool
keeper/data

# secrets and local artefacts — never commit these
backups
.env
db/generated
web/.env.local
scripts/api.env

# build output — the SDK's dist/ is produced by `npm install` (postinstall → sdk:build).
# Committing it meant a stale bundle could ship while src/ said otherwise.
sdk/dist
web/.next
web/out
dist
*.tsbuildinfo

# logs and local dumps
*.log
npm-debug.log*

# local validator ledger (npm run test:anchor)
.test-ledger

# generated build outputs (npm run audit / npm run coverage). docs/ was removed as
# a hand-written docs folder; these are regenerated locally and are not committed.
docs/INTEGRITY_AUDIT.md
docs/COVERAGE.md
