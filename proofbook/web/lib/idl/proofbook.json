            "docs": [
              "Batch timestamp (Unix ms) whose daily root was checked."
            ],
            "type": "i64"
          },
          {
            "name": "epoch_day",
            "docs": [
              "`floor(proof_ts / 86_400_000)` — the daily-root epoch day."
            ],
            "type": "u16"
          },
          {
            "name": "daily_roots",
            "docs": [
              "The oracle `daily_scores_merkle_roots` PDA verified against."
            ],
