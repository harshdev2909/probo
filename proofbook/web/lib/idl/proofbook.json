      "docs": [
        "Emitted on trustless settlement — the full Proof Receipt data contract.",
        "See `docs/ONCHAIN_INTERFACE.md` for how to reconstruct & verify a receipt."
      ],
      "type": {
        "kind": "struct",
        "fields": [
