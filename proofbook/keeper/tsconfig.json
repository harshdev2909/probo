{
  "compilerOptions": {
    "types": [
      "node",
      "mocha"
    ],
    "lib": [
      "es2020"
    ],
    "module": "commonjs",
    "target": "es2020",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "scripts/**/*.ts",
    "../data/**/*.ts",
    "../db/src/**/*.ts",
    "../db/generated/**/*.ts",
    "../api/src/**/*.ts"
  ]
}